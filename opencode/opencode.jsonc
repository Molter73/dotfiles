{
  "$schema": "https://opencode.ai/config.json",
  "lsp": true,
  "permission": {
      "*": "ask",
      "bash": {
          "cargo *": "allow",
          "cargo install *": "ask",
          "echo *": "allow",
          "git add *": "allow",
          "git commit *": "allow",
          "git diff *": "allow",
          "git log *": "allow",
          "git push *": "deny",
          "git submodule update *": "allow",
          "head *": "allow",
          "ls *": "allow",
          "make *": "allow",
          "python3 *": "allow",
          "tail *": "allow"
      },
      "grep": "allow",
      "glob": "allow",
      "read": "allow",
      "lsp": "allow",
      "edit": "allow",
      "todowrite": "allow"
  }
}
