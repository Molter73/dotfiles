{
  "$schema": "https://opencode.ai/config.json",
  "lsp": true,
  "permission": {
    "*": "ask"
  },
  "agent": {
    "build": {
      "permission": {
        "*": "ask",
        "bash": {
          "cargo *": "allow",
          "cargo install *": "ask",
          "coderabbit review *": "allow",
          "cp *": "allow",
          "cr review *": "allow",
          "echo *": "allow",
          "find *": "allow",
          "fd *": "allow",
          "git add *": "allow",
          "git commit *": "allow",
          "git diff *": "allow",
          "git log *": "allow",
          "git push *": "deny",
          "git status *": "allow",
          "git submodule update *": "allow",
          "grep *": "allow",
          "head *": "allow",
          "ls *": "allow",
          "make *": "allow",
          "mkdir *": "allow",
          "rg *": "allow",
          "sort *": "allow",
          "tree *": "allow",
          "tail *": "allow"
        },
        "skills": {
          "code-review": "allow"
        },
        "grep": "allow",
        "glob": "allow",
        "read": "allow",
        "lsp": "allow",
        "edit": "allow",
        "todowrite": "allow"
      }
    }
  }
}
