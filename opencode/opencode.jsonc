{
  "$schema": "https://opencode.ai/config.json",
  "lsp": true,
  "default_agent": "plan",
  "permission": {
    "*": "ask",
    "bash": {
      "cat *": "allow",
      "echo *": "allow",
      "fd *": "allow",
      "find *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git status *": "allow",
      "git push *": "deny",
      "grep *": "allow",
      "head *": "allow",
      "ls *": "allow",
      "rg *": "allow",
      "sort *": "allow",
      "tail *": "allow",
      "tree *": "allow",
      "wc *": "allow"
    },
    "glob": "allow",
    "grep": "allow",
    "lsp": "allow",
    "read": "allow",
    "todowrite": "allow"
  },
  "agent": {
    "build": {
      "color": "#f38ba8",
      "permission": {
        "bash": {
          "cargo *": "allow",
          "cargo install *": "ask",
          "cp *": "allow",
          "git add *": "allow",
          "git commit *": "allow",
          "git submodule update *": "allow",
          "make *": "allow",
          "mkdir *": "allow",
          "mv *": "allow"
        },
        "skills": {
          "code-review": "allow"
        },
        "task": "allow",
        "edit": "allow"
      }
    },
    "plan": {
      "color": "#89dceb",
      "permission": {
        "bash": {
          "cargo check *": "allow",
          "cargo clippy *": "allow",
          "coderabbit *": "allow",
          "cr *": "allow"
        },
        "skills": {
          "code-review": "allow"
        },
        "task": "allow"
      }
    },
    "general": {
      "permission": {
        "bash": {
          "cargo *": "allow",
          "cargo install *": "ask",
          "cp *": "allow",
          "git add *": "allow",
          "git commit *": "allow",
          "git submodule update *": "allow",
          "make *": "allow",
          "mkdir *": "allow",
          "mv *": "allow"
        },
        "skills": {
          "code-review": "allow"
        },
        "task": "allow",
        "edit": "allow"
      }
    }
  }
}
